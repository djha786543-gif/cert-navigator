# ============================================================
# Career Navigator v2 — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================

# ── Application ─────────────────────────────────────────────
DEBUG=false
APP_NAME="Career Navigator — Resilience Engine"

# ── Security (REQUIRED — generate with: openssl rand -hex 32)
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── PostgreSQL ───────────────────────────────────────────────
# Docker: leave as-is. Local: adjust to your PostgreSQL instance.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/career_navigator
POSTGRES_PASSWORD=postgres

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Embedding Model ─────────────────────────────────────────
# Requires: pip install sentence-transformers
# Downloads ~80 MB on first run. Stored in ~/.cache/huggingface/
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Job APIs ─────────────────────────────────────────────────
# Adzuna — https://developer.adzuna.com (free tier: 250 req/day)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Reed.co.uk — https://www.reed.co.uk/developers (India/UK market)
REED_API_KEY=
# JSearch (RapidAPI) — backup; 500 req/month free
JSEARCH_API_KEY=

# ── LLM (Phase 3 — Artifact Sovereign) ──────────────────────
# ⚠️ CAPACITY FLAG: Uncomment ONE provider.
# GPT-4o: ~$0.15/artifact  |  Claude Sonnet: ~$0.12/artifact
# For 50 concurrent: burst cost = $6-7.50. Rate-limit to 5 concurrent tasks.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic

# ── Market Default ───────────────────────────────────────────
# "US" (Los Angeles / NYC tech market) | "IN" (Bangalore / Mumbai)
DEFAULT_MARKET=US

# ── Flower (Celery monitoring) ───────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# ── CORS ─────────────────────────────────────────────────────
# Add production URL when deploying (e.g., https://yourapp.com)
# CORS_ORIGINS=["http://localhost:3000","https://yourapp.com"]
