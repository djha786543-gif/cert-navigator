{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Career Navigator — API, Celery, Proctor, and DB metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "API Health",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["last"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "API Status",
      "type": "stat",
      "targets": [{ "expr": "up{job=\"career_api\"}", "legendFormat": "API" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 1 },
      "id": 2,
      "title": "Request Rate (RPS)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m])) by (endpoint)", "legendFormat": "{{endpoint}}" }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 1 },
      "id": 3,
      "title": "Response Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red",   "value": 0.01 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "orientation": "auto", "colorMode": "background" },
      "title": "Error Rate (5xx)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Celery Workers",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 10,
      "title": "Celery Task Rate (success / failure)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(celery_task_total{status=\"success\"}[5m])) by (task_name)",
          "legendFormat": "success: {{task_name}}"
        },
        {
          "expr": "sum(rate(celery_task_total{status=\"failure\"}[5m])) by (task_name)",
          "legendFormat": "FAILURE: {{task_name}}"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 11,
      "title": "Celery Task Duration p95 by Task",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket[10m])) by (task_name, le))",
          "legendFormat": "p95 {{task_name}}"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Proctor & Business Metrics",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 19 },
      "id": 20,
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background" },
      "title": "Active Proctor Sessions",
      "type": "stat",
      "targets": [{ "expr": "proctor_active_sessions", "legendFormat": "sessions" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 19 },
      "id": 21,
      "options": { "reduceOptions": { "calcs": ["last"] }, "colorMode": "background" },
      "title": "Artifact Queue Depth",
      "type": "stat",
      "targets": [{ "expr": "artifact_queue_depth", "legendFormat": "queued" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 19 },
      "id": 22,
      "title": "Circuit Breaker State (0=closed, 1=open)",
      "type": "timeseries",
      "targets": [
        { "expr": "circuit_breaker_open", "legendFormat": "{{service}}" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Infrastructure",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "title": "HTTP Active Requests",
      "type": "timeseries",
      "targets": [{ "expr": "http_active_requests", "legendFormat": "active" }]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "pg_stat_activity_count", "legendFormat": "connections" }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["career-navigator", "api", "celery"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Career Navigator",
  "uid": "career-navigator-v1",
  "version": 1
}
